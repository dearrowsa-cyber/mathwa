# Production Environment Configuration for mathwaa.org.sa
# These variables are used when building: npm run build

# API endpoint for production
VITE_API_URL=https://mathwaa.org.sa/Backend/api
VITE_BACKEND_URL=https://mathwaa.org.sa/Backend

# Alternative using relative paths (if on same server)
# VITE_API_URL=/Backend/api
# VITE_BACKEND_URL=/Backend

