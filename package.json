{
  "name": "mathwa-charity-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext vue,js,jsx,cjs,mjs --fix --ignore-path .gitignore",
    "deploy": "node deploy.mjs",
    "deploy:front": "node deploy.mjs --front",
    "deploy:back": "node deploy.mjs --back",
    "deploy:all": "node deploy.mjs --all",
    "deploy:quick": "node deploy.mjs --skip-build",
    "deploy:force": "node deploy.mjs --force --all",
    "postbuild": "react-snap"
  },
  "reactSnap": {
    "include": [
      "/",
      "/about",
      "/governance",
      "/board-members",
      "/annual-reports",
      "/membership"
    ]
  },
  "dependencies": {
    "axios": "^1.6.2",
    "framer-motion": "^12.34.1",
    "i18next": "^23.7.6",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.2.0",
    "react-fast-marquee": "^1.6.5",
    "react-i18next": "^13.5.0",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "basic-ftp": "^5.2.0",
    "postcss": "^8.4.32",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.0",
    "vite": "^5.0.8"
  }
}
